<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Controle Total Premium</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>controle_total_premium</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>googlechrome</string>
		<string>googlechromes</string>
	</array>
	<!-- Obrigatório para Google Sign-In no iOS (OAuth volta ao app). Valor = REVERSED_CLIENT_ID do GoogleService-Info.plist -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.766524666378-glgtv4te1i3s4fr67v1t89q57d2hcm9l</string>
			</array>
		</dict>
	</array>
	<!-- Google Sign-In iOS: CLIENT_ID do GoogleService-Info.plist (evita falha silenciosa / rejeição em revisão) -->
	<key>GIDClientID</key>
	<string>766524666378-glgtv4te1i3s4fr67v1t89q57d2hcm9l.apps.googleusercontent.com</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>O app usa a câmara para tirar foto de comprovantes financeiros, anexos e orçamentos quando você escolher essa opção.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>O app acessa a galeria para anexar fotos, prints e PDFs salvos em comprovantes financeiros e anotações.</string>
	<!-- iOS 14+ (PHPicker / acesso limitado): mesma finalidade; evita rejeição por falta de chave em revisões estritas -->
	<key>NSPhotoLibraryLimitedUsageDescription</key>
	<string>O app usa fotos que você selecionar da galeria para anexar em comprovantes e anotações.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Usamos Face ID ou Touch ID para desbloquear o app com segurança, se você ativar essa opção nas configurações.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>O Controle Total envia lembretes de escalas, compromissos, audiências e folgas no horário que você configurou.</string>
	<!-- Apple 90683: SDKs podem referenciar Core Location; o app não rastreia GPS em segundo plano -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>O Controle Total não usa sua localização em segundo plano. A permissão só se aplica se você abrir um endereço em mapas externos (quando disponível) ou se uma biblioteca do sistema solicitar acesso pontual.</string>
	<!-- Conformidade de exportação (EAR): só HTTPS/TLS típico de APIs — isento; reduz aviso "Faltam dados de conformidade" no TestFlight -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
